FROM node:20-alpine

WORKDIR /app

RUN corepack enable

COPY package.json pnpm-lock.yaml ./
COPY apps/worker/package.json ./apps/worker/
COPY packages/*/package.json ./packages/

RUN pnpm install --frozen-lockfile --filter=@flowforge/worker

COPY . .

WORKDIR /app/apps/worker

CMD ["npm", "run", "dev"]